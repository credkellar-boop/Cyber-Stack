# Cyber-Stack Environment Variables Template
# Copy this file to .env and populate with your credentials

# HuggingFace Token for downloading gated models (like Llama 3)
HF_TOKEN=hf_your_token_here_xxxxxx

# Logging level for the Rust Orchestrator (trace, debug, info, warn, error)
RUST_LOG=info

# Internal routing IP for the Triton Inference Server
TRITON_URL=127.0.0.1:8000

# Path to the compiled Linux kernel for syzkaller fuzzing
KERNEL_OBJ_PATH=/usr/src/linux
