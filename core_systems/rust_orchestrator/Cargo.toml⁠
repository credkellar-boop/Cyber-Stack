[package]
name = "rust_orchestrator"
version = "0.1.0"
edition = "2021"

[dependencies]
# Async runtime
tokio = { version = "1", features = ["full"] }
anyhow = "1"
log = "0.4"
env_logger = "0.11"

# eBPF user-space loader
aya = "0.11"
aya-log = "0.1"

# JSON and HTTP
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
reqwest = { version = "0.11", features = ["json"] }

# In-memory YARA scanning
yara = "0.18"

[build-dependencies]
cc = "1.0"

aya-log = "0.1"

